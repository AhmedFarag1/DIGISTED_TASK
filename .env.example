# --- Google Gemini (generation / LLM only) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GENERATION_TEMPERATURE=0.2
GENERATION_MAX_TOKENS=384

# --- Embeddings: multilingual-e5-large (local, Sentence Transformers) ---
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024
EMBEDDING_MAX_TOKENS=512
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu

# --- Qdrant (local Docker via docker-compose.yml) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=natural_questions
QDRANT_PREFER_GRPC=false

# --- Dataset / chunking (TOKEN counts — same tokenizer as E5 model) ---
DATASET_PATH=dataset/Natural-Questions-Filtered.csv
CHUNK_SIZE=256
CHUNK_OVERLAP=32
MAX_INGEST_ROWS=2000

# --- Retrieval / RAG ---
TOP_K=5
CANDIDATE_MULTIPLIER=2
QUERY_EXPANSION_ENABLED=false
MIN_CONFIDENCE=0.30
CACHE_CAPACITY=512
CONTEXT_MAX_CHARS=2800
EMBEDDING_NUM_THREADS=4

# --- Persistence (Phase 3) ---
DATABASE_URL=sqlite:///./rag_platform.db

# --- Server ---
HOST=127.0.0.1
PORT=8000

# --- Hugging Face Hub (optional — higher rate limits, faster model downloads) ---
HF_TOKEN=your-hf-read-token-here
